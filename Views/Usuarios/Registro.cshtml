@model NutriPlan.Models.Usuario
@{
    ViewData["Title"] = "Crear Cuenta";
}

<div class="login-page">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 col-lg-5">
                <div class="card login-card shadow-lg border-0 p-4" id="register-container">
                    <div class="text-center mb-4">
                        <img src="~/images/logo-nutriplan.png" alt="NutriPlan" class="img-fluid mb-3" style="max-height: 60px;">
                        <h2 class="fw-bold text-dark">Únete a NutriPlan</h2>
                        <p class="text-muted small">Crea tu cuenta para empezar tu vida saludable</p>
                    </div>

                    <form asp-action="Registro" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="planElegido" value="@Model?.PlanElegido" />

                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label small fw-bold">Correo Electrónico</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-envelope"></i></span>
                                    <input asp-for="CorreoElectronico" type="email" class="form-control bg-light border-start-0" placeholder="email@ejemplo.com" required />
                                </div>
                                <span asp-validation-for="CorreoElectronico" class="text-danger small"></span>
                            </div>

                            <div class="col-12">
                                <label class="form-label small fw-bold">Contraseña</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-lock"></i></span>
                                    <input asp-for="ContrasenaHash" type="password" class="form-control bg-light border-start-0" placeholder="••••••••" required />
                                </div>
                                <span asp-validation-for="ContrasenaHash" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-4">
                                <button type="submit" class="btn btn-success w-100 py-3 fw-bold shadow-sm">
                                    Crear mi cuenta
                                </button>
                            </div>
                        </div>

                        <div class="text-center mt-4">
                            <p class="small text-muted">¿Ya tienes cuenta? 
                                <a asp-action="Login" class="text-success fw-bold text-decoration-none">Inicia sesión</a>
                            </p>
                            <a asp-controller="Home" asp-action="Index" class="small text-secondary text-decoration-none">
                                <i class="bi bi-arrow-left"></i> Volver al inicio
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>