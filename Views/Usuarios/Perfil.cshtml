@model NutriPlan.Models.Usuario
@{
    ViewData["Title"] = "Mi Perfil";
}

<div class="container py-5" id="perfil-content">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm p-4 text-center mb-4" style="border-radius: 20px;">
                <div class="position-relative d-inline-block mx-auto mb-3">
                    <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 80px; height: 80px; font-size: 2rem;">
                        @(Model?.CorreoElectronico?.Substring(0, 1).ToUpper() ?? "U")
                    </div>
                </div>
                <h4 class="fw-bold mb-1">Mi Cuenta</h4>
                <p class="text-muted small">@Model?.CorreoElectronico</p>
                
                <hr class="my-4 opacity-25">
                
                <div class="text-start">
                    <p class="small mb-1 text-muted">ID de Usuario</p>
                    <p class="fw-bold">#@Model?.IdUsuario</p>
                </div>

                <a asp-action="Logout" class="btn btn-outline-danger w-100 mt-3 rounded-pill btn-sm">
                    <i class="bi bi-box-arrow-right me-2"></i>Cerrar Sesión
                </a>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 20px;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Mi Plan Actual</h5>
                    <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">Activo</span>
                </div>

                <div class="p-4 bg-light rounded-4 border-start border-success border-4 mb-4">
                    <div class="row align-items-center">
                        <div class="col-md-8">
                            <h3 class="text-success fw-bold">Plan @(Model?.PlanElegido ?? "No seleccionado")</h3>
                            <p class="text-muted mb-0">Generado según tus preferencias de salud.</p>
                        </div>
                        <div class="col-md-4 text-md-end mt-3 mt-md-0">
                            <a asp-action="SeleccionPlan" class="btn btn-success rounded-pill px-4">
                                Cambiar Plan
                            </a>
                        </div>
                    </div>
                </div>

                <h6 class="fw-bold mb-3">Accesos Rápidos</h6>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <a asp-action="MiPlan" class="card h-100 border-0 bg-white shadow-sm p-3 text-decoration-none text-dark hover-card">
                            <div class="d-flex align-items-center">
                                <div class="icon-box-small bg-primary-subtle text-primary me-3">
                                    <i class="bi bi-calendar-week"></i>
                                </div>
                                <div>
                                    <p class="mb-0 fw-bold">Ver Calendario</p>
                                    <span class="small text-muted">Comidas de la semana</span>
                                </div>
                            </div>
                        </a>
                    </div>
                    <div class="col-sm-6">
                        <a asp-action="ListaCompra" class="card h-100 border-0 bg-white shadow-sm p-3 text-decoration-none text-dark hover-card">
                            <div class="d-flex align-items-center">
                                <div class="icon-box-small bg-warning-subtle text-warning me-3">
                                    <i class="bi bi-cart"></i>
                                </div>
                                <div>
                                    <p class="mb-0 fw-bold">Lista de Compra</p>
                                    <span class="small text-muted">Ingredientes necesarios</span>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>