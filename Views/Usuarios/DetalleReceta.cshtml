@model NutriPlan.Models.Receta
@{
    ViewData["Title"] = Model.Nombre;
}

<div class="container py-5">
    <a asp-action="MiPlan" class="btn btn-link text-success p-0 mb-4 text-decoration-none">
        <i class="bi bi-arrow-left"></i> Volver al calendario
    </a>

    <div class="row g-5">
        <div class="col-lg-5">
            <div class="sticky-top" style="top: 20px;">
                <div class="rounded-4 overflow-hidden shadow-lg mb-4">
                    <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?q=80&w=1000&auto=format&fit=crop" 
                         alt="@Model.Nombre" class="img-fluid w-100" style="object-fit: cover; height: 400px;">
                </div>
                
                <div class="card border-0 shadow-sm p-4 rounded-4">
                    <h2 class="fw-bold">@Model.Nombre</h2>
                    <div class="d-flex gap-3 mt-3">
                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill">
                            <i class="bi bi-fire me-1"></i> @Model.Calorias kcal
                        </span>
                        <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill">
                            <i class="bi bi-clock me-1"></i> @Model.MomentoDia
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card border-0 shadow-sm p-4 mb-4 rounded-4">
                <h4 class="fw-bold mb-4"><i class="bi bi-basket text-success me-2"></i>Ingredientes</h4>
                <ul class="list-group list-group-flush">
                    @if (!string.IsNullOrEmpty(Model.Ingredientes))
                    {
                        @foreach (var ing in Model.Ingredientes.Split(','))
                        {
                            <li class="list-group-item border-0 px-0">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="@ing.Trim().Replace(" ", "-")">
                                    <label class="form-check-label" for="@ing.Trim().Replace(" ", "-")">
                                        @ing.Trim()
                                    </label>
                                </div>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item border-0 px-0 text-muted">Ingredientes no disponibles.</li>
                    }
                </ul>
            </div>

            <div class="card border-0 shadow-sm p-4 rounded-4">
                <h4 class="fw-bold mb-4"><i class="bi bi-journal-text text-success me-2"></i>Preparación</h4>
                <div class="preparation-text text-muted" style="line-height: 1.8;">
                    <p>Para cocinar <strong>@Model.Nombre</strong>, sigue los pasos habituales de este tipo de plato. 
                    Próximamente añadiremos la guía paso a paso detallada en la base de datos.</p>
                </div>
            </div>
        </div>
    </div>
</div>