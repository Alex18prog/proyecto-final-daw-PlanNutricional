@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Inicio";
}

<section class="hero-section text-center">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-8">
                
                <div class="logo-wrapper mb-5">
                    <img src="~/images/logo-nutriplan.png" alt="NutriPlan Logo" class="img-fluid logo-main-img shadow" style="max-height: 200px;">
                </div>
                
                <p class="lead mb-5 text-secondary px-3">
                    La plataforma inteligente para gestionar tu dieta, alcanzar tus objetivos y organizar tu vida saludable de forma automática.
                </p>

                @if (Context.Session.GetInt32("UsuarioId") != null)
                {
                    <div class="alert alert-success d-inline-block px-5 shadow-sm border-0 mb-4 rounded-pill">
                        <i class="bi bi-check-circle-fill me-2"></i> 
                        ¡Hola de nuevo! Tu plan personalizado te espera.
                    </div>
                    <div class="d-grid gap-3 d-sm-flex justify-content-sm-center">
                        <a asp-controller="Usuarios" asp-action="MiPlan" class="btn btn-success btn-cta shadow">
                            <i class="bi bi-calendar-week me-2"></i> Ver mi Calendario
                        </a>
                        <a asp-controller="Usuarios" asp-action="Perfil" class="btn btn-outline-dark btn-cta">
                            <i class="bi bi-person-circle me-2"></i> Mi Perfil
                        </a>
                    </div>
                }
                else
                {
                    <div class="d-grid gap-3 d-sm-flex justify-content-sm-center mt-3">
                        <a asp-controller="Usuarios" asp-action="Registro" class="btn btn-success btn-cta shadow">
                            ¡Empezar ahora!
                        </a>
                        <a asp-controller="Usuarios" asp-action="Login" class="btn btn-outline-dark btn-cta">
                            Iniciar Sesión
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</section>

<section class="container mb-5 mt-4">
    <div class="row g-4 text-center justify-content-center">
        <div class="col-md-4">
            <a asp-controller="Usuarios" asp-action="Planes" class="text-decoration-none card-wrapper">
                <div class="card h-100 feature-card shadow-sm p-4 border-0 clickable-card" style="cursor: pointer;">
                    <div class="icon-box mx-auto">
                        <i class="bi bi-journal-check"></i>
                    </div>
                    <h4 class="text-dark">Planes a medida</h4>
                    <p class="text-muted small">Recetas adaptadas a tus objetivos de peso y salud.</p>
                </div>
            </a>
        </div>
    </div>
</section>