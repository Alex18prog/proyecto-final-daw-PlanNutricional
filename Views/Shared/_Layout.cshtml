<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NutriPlan</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NutriPlan.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        @* Lógica para ocultar la Navbar solo en el Home *@
        @{
            var isHome = ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && 
                         ViewContext.RouteData.Values["action"]?.ToString() == "Index";
        }

        @if (!isHome)
        {
            <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom shadow-sm mb-3">
                <div class="container">
                    <a class="navbar-brand fw-bold text-success" asp-controller="Home" asp-action="Index">
                        NutriPlan
                    </a>
                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                        <ul class="navbar-nav flex-grow-1">
                            <li class="nav-item">
                                <a class="nav-link text-dark nav-custom-link" asp-controller="Usuarios" asp-action="Planes">
                                    <i class="bi bi-journal-check"></i> Planes a medida
                                </a>
                            </li>
                        </ul>
                        <ul class="navbar-nav">
                            @if (Context.Session.GetInt32("UsuarioId") != null)
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark nav-custom-link" asp-controller="Usuarios" asp-action="Perfil">
                                        <i class="bi bi-person-circle"></i> Mi Perfil
                                    </a>
                                </li>
                                <li class="nav-item ms-lg-2">
                                    <a class="btn btn-outline-danger btn-sm mt-1" asp-controller="Usuarios" asp-action="Logout">Salir</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        }
    </header>

    @* Si es Home, quitamos el 'container' para que el Hero ocupe todo el ancho *@
    <div class="@(isHome ? "" : "container")">
        <main role="main" class="@(isHome ? "" : "pb-3")">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-white py-3">
        <div class="container text-center">
            &copy; 2026 - <strong>NutriPlan</strong>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>